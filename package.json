{
  "name": "brizbuilder",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "test": "npm run test:security && npm run build && node --test tests/crm.integration.test.mjs",
    "test:security": "npm run test:oauth && npm run test:ai-connector && npm run test:ai-gateway && npm run test:stripe",
    "test:oauth": "node --experimental-strip-types --test tests/ai-oauth-security.test.mjs",
    "test:ai-connector": "node --test tests/ai-connector-security.test.mjs",
    "test:ai-gateway": "node --experimental-strip-types --test tests/ai-gateway.test.mjs",
    "test:stripe": "node --test tests/stripe-connect-security.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern work",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:pg:generate": "drizzle-kit generate --config drizzle.supabase.config.ts",
    "db:pg:push": "drizzle-kit push --config drizzle.supabase.config.ts",
    "db:pg:studio": "drizzle-kit studio --config drizzle.supabase.config.ts"
  },
  "dependencies": {
    "@jridgewell/sourcemap-codec": "1.5.5",
    "@supabase/server": "^1.4.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "drizzle-orm": "0.45.2",
    "jose": "^6.2.4",
    "next": "16.2.6",
    "postgres": "^3.4.9",
    "qrcode.react": "^4.2.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "miniflare": "4.20260515.0",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
