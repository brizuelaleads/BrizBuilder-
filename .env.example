# Optional localhost-only overrides. Do not reuse these values in production.
MAIN_ADMIN_EMAIL=admin@example.com
MAIN_ADMIN_NAME=Main Administrator
LOCAL_DEV_ADMIN_PASSWORD=choose-a-local-test-password
LOCAL_DEV_SESSION_TOKEN=replace-with-a-long-random-local-token

# Cloudflare deploy:
# Leave these blank to deploy the public website without a D1 binding.
# Set them after creating a real Cloudflare D1 database to enable the protected dashboard database.
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_D1_DATABASE_NAME=brizbuilder-d1

# Supabase backend:
# Copy these from Supabase Project Settings > API.
# Never commit the real service-role key to GitHub.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# New Supabase projects may call these "publishable" and "secret" keys.
# The app supports these aliases too.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_LEAD_CAPTURE_BASE_URL=https://brizbuilder-leads.brizuelaleads.workers.dev
SUPABASE_SECRET_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_JWKS_URL=
SUPABASE_DATABASE_URL=
BRIZBUILDER_BACKEND=d1

# Reserved for later phases. The Phase 1 application does not read these yet.
OPENAI_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
RESEND_API_KEY=
STRIPE_SECRET_KEY=
META_APP_ID=
META_APP_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
