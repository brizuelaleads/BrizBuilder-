# Optional localhost-only overrides. Do not reuse these values in production.
MAIN_ADMIN_EMAIL=admin@example.com
MAIN_ADMIN_NAME=Main Administrator
LOCAL_DEV_ADMIN_PASSWORD=choose-a-local-test-password
LOCAL_DEV_SESSION_TOKEN=replace-with-a-long-random-local-token

# Cloudflare Access protects the production dashboard. Copy TEAM_DOMAIN from
# Zero Trust > Settings and the application's AUD tag from
# Access controls > Applications > BrizBuilder > Additional settings.
TEAM_DOMAIN=https://your-team-name.cloudflareaccess.com
POLICY_AUD=your-cloudflare-access-application-aud-tag

# Worker integration-test authentication only. Do not set these on production.
BRIZBUILDER_TEST_AUTH_ENABLED=false
BRIZBUILDER_TEST_AUTH_SECRET=
BRIZBUILDER_TEST_AUTH_HOST=127.0.0.1

# Cloudflare deploy:
# Leave these blank to deploy the public website without a D1 binding.
# Set them after creating a real Cloudflare D1 database to enable the protected dashboard database.
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_D1_DATABASE_NAME=brizbuilder-d1

# Supabase backend:
# Copy these from Supabase Project Settings > API.
# Never commit the real service-role key to GitHub.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# New Supabase projects may call these "publishable" and "secret" keys.
# The app supports these aliases too.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_LEAD_CAPTURE_BASE_URL=https://brizbuilder-leads.brizuelaleads.workers.dev
SUPABASE_SECRET_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_JWKS_URL=
SUPABASE_DATABASE_URL=
BRIZBUILDER_BACKEND=d1

# Public HTTPS origin used by the remote AI connector and its OAuth metadata.
# This connector does not use OPENAI_API_KEY or any other paid model API key.
BRIZBUILDER_PUBLIC_ORIGIN=https://brizbuilder.brizuelaleads.workers.dev

# Phone system. Keep the Auth Token secret in Cloudflare; never expose it in the browser.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WEBHOOK_BASE_URL=https://brizbuilder-leads.brizuelaleads.workers.dev
# Paste the authorization URL from Twilio Console > Settings > Connect applications.
TWILIO_CONNECT_AUTHORIZE_URL=
TWILIO_CONNECT_APP_SID=

# Google Business Profile OAuth. Keep the client secret and encryption key only
# in Cloudflare secrets. The encryption key must decode to exactly 32 bytes.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://brizbuilder.brizuelaleads.workers.dev/api/integrations/google/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=
GOOGLE_OAUTH_STATE_SECRET=

# Reserved for later phases. OPENAI_API_KEY is intentionally not required by
# the AI Connector; customers use their own compatible AI account and plan.
RESEND_API_KEY=
STRIPE_SECRET_KEY=
META_APP_ID=
META_APP_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
